<%= form_with(model: player) do |form| %>
  <% if player.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(player.errors.count, "error") %> prohibited this player from being saved:</h2>

      <ul>
        <% player.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :Player_ID, style: "display: block" %>
    <%= form.number_field :Player_ID %>
  </div>

  <div>
    <%= form.label :First_Name, style: "display: block" %>
    <%= form.text_field :First_Name %>
  </div>

  <div>
    <%= form.label :Last_Name, style: "display: block" %>
    <%= form.text_field :Last_Name %>
  </div>

  <div>
    <%= form.label :Current, style: "display: block" %>
    <%= form.checkbox :Current %>
  </div>

  <div>
    <%= form.label :Bats, style: "display: block" %>
    <%= form.select :Bats, options_for_select(Player.bats.keys.map { |key| [key, key] }) %>
  </div>

  <div>
    <%= form.label :Throws, style: "display: block" %>
    <%= form.select :Throws, options_for_select(Player.throws.keys.map { |key| [key, key] }) %>
  </div>

  <div>
    <%= form.label :POS1, style: "display: block" %>
    <%= form.select :POS1, options_for_select(Player::POSITIONS.map { |key, value| [key, key] }) %>
  </div>

  <div>
    <%= form.label :POS2, style: "display: block" %>
    <%= form.select :POS2, options_for_select(Player::POSITIONS.map { |key, value| [key, key] }) %>
  </div>

  <div>
    <%= form.label :POS3, style: "display: block" %>
    <%= form.select :POS3, options_for_select(Player::POSITIONS.map { |key, value| [key, key] }) %>
  </div>

  <div>
    <%= form.label :Nickname, style: "display: block" %>
    <%= form.text_field :Nickname %>
  </div>

  <div>
    <%= form.label :Hometown, style: "display: block" %>
    <%= form.text_field :Hometown %>
  </div>

  <div>
    <%= form.label :Divorces, style: "display: block" %>
    <%= form.number_field :Divorces %>
  </div>

  <div>
    <%= form.label :DOB, style: "display: block" %>
    <%= form.datetime_field :DOB %>
  </div>

  <div>
    <%= form.label :Height, style: "display: block" %>
    <%= form.number_field :Height %>
  </div>

  <div>
    <%= form.label :Weight, style: "display: block" %>
    <%= form.number_field :Weight %>
  </div>

  <div>
    <%= form.label :Image, style: "display: block" %>
    <%= form.checkbox :Image %>
  </div>

  <div>
    <%= form.label :uniform, style: "display: block" %>
    <%= form.number_field :uniform %>
  </div>

  <div>
    <%= form.label :email, style: "display: block" %>
    <%= form.text_field :email %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
